generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  INCHARGE
  EMPLOYEE
}

enum UserStatus {
  PENDING_EMAIL
  PENDING_APPROVAL
  ACTIVE
  REJECTED
  SUSPENDED
}

enum DepartmentType {
  MARKETING
  OPERATIONS
  TUTOR
  ACCOUNTS
  DIGITAL_MARKETING
}

enum Country {
  NORTH_AMERICA
  EUROPE
  AUSTRALIA
}

enum ReportStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OperationReportStatus {
  DRAFT
  SUBMITTED
  WAITING_FOR_SYNC
  VERIFIED
  MISMATCH
  CORRECTION_REQUIRED
  REJECTED
}

model Department {
  id   String         @id @default(cuid())
  name String
  type DepartmentType @unique

  users User[]

  inchargeId String? @unique

  incharge User? @relation("DepartmentIncharge", fields: [inchargeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id String @id @default(cuid())

  fullName String
  username String @unique
  email    String @unique
  phone    String @unique

  passwordHash String

  employeeCode    String?  @unique
  profileImageUrl String?
  coverImageUrl   String?

  role   Role       @default(EMPLOYEE)
  status UserStatus @default(PENDING_EMAIL)

  emailVerified Boolean @default(false)

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])

  documents VerificationDocument[]

  marketingReports MarketingReport[]

  operationReports EmployeeOperationReport[]

  attendances Attendance[]

  leaves Leave[]

  managedDepartment Department? @relation("DepartmentIncharge")

  approvedMarketingReports MarketingReport[] @relation("MarketingApproval")

  approvedById String?

  approvedBy User? @relation("UserApproval", fields: [approvedById], references: [id])

  approvedEmployees User[] @relation("UserApproval")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationDocument {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  documentName String
  documentType String
  documentUrl  String

  isVerified Boolean @default(false)

  uploadedAt DateTime @default(now())
}

model MarketingReport {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  reportDate DateTime

  country Country

  whatsappGroupsJoined Int @default(0)
  whatsappPostsDone    Int @default(0)

  telegramGroupsJoined Int @default(0)
  telegramPostsDone    Int @default(0)

  facebookGroupsJoined Int @default(0)
  facebookPostsDone    Int @default(0)

  resourceLogin Int @default(0)
  accountClean  Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  status ReportStatus @default(PENDING)

  remarks String?

  approvedById String?
  approvedBy   User?   @relation("MarketingApproval", fields: [approvedById], references: [id])

  @@unique([userId, country, reportDate])
}

model Attendance {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  attendanceDate DateTime

  checkIn  DateTime?
  checkOut DateTime?

  status AttendanceStatus @default(PRESENT)

  remarks String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, attendanceDate])
}

model Leave {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  fromDate DateTime
  toDate   DateTime

  reason String

  status LeaveStatus @default(PENDING)

  approvedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmployeeOperationReport {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  reportDate DateTime

  queryGenerated  Int @default(0)
  dealsDone       Int @default(0)
  tutorAssigned   Int @default(0)
  dealsDoneAmount Int @default(0)

  workNotes String?

  status OperationReportStatus @default(DRAFT)

  submittedAt DateTime?
  lockedAt    DateTime?

  reviewedById  String?
  reviewedAt    DateTime?
  reviewRemarks String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, reportDate])
  @@index([reportDate])
  @@index([status])
}
